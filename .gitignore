# Allowlist gitignore. Files are committed only if explicitly un-ignored below.
**

# Project structure
!*/
!.gitignore
!.editorconfig
!.github/
!.github/**
!.cargo/
!.cargo/config.toml

# Rust crate
!Cargo.toml
!Cargo.lock
!src/
!src/**
!tests/
!tests/**
!benches/
!benches/**
!examples/
!examples/**

# Top-level docs and config
!README.md
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!Taskfile.yml
!.anodizer.yaml
!rust-toolchain.toml
!rustfmt.toml
!clippy.toml
!deny.toml

# Build/output (re-ignore even if matched above)
target/
dist/
**/*.rs.bk
Cargo.lock.bak

# Session-local artifacts (never commit)
.claude/
.task/
.worktrees/
*.local.md
mcp-tools.json
